@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    @await Component.InvokeAsync("_HeadLayoutViewComponentPartial")
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div class="boxed_wrapper rtl"> </div>


        <!-- preloader -->
        @await Component.InvokeAsync("_PreLoaderViewComponentPartial")
        <!-- preloader end -->
       
        <!-- main header -->
        @await Component.InvokeAsync("_HeaderLayoutViewComponentPartial")
        <!-- main-header end -->
        <!-- Mobile Menu  -->
        <div class="mobile-menu">
            <div class="menu-backdrop"></div>
            <div class="close-btn"><i class="fas fa-times"></i></div>

            <nav class="menu-box">
                <div class="nav-logo"><a href="/Realshed/index.html"><img src="/Realshed/assets/images/logo-2.png" alt="" title=""></a></div>
                <div class="menu-outer"></div>
                <div class="contact-info">
                    <h4>Contact Info</h4>
                    <ul>
                        <li>Chicago 12, Melborne City, USA</li>
                        <li><a href="tel:+8801682648101">+88 01682648101</a></li>
                        <li><a href="mailto:info@example.com">info@example.com</a></li>
                    </ul>
                </div>
                <div class="social-links">
                    <ul class="clearfix">
                        <li><a href="/Realshed/index.html"><span class="fab fa-twitter"></span></a></li>
                        <li><a href="/Realshed/index.html"><span class="fab fa-facebook-square"></span></a></li>
                        <li><a href="/Realshed/index.html"><span class="fab fa-pinterest-p"></span></a></li>
                        <li><a href="/Realshed/index.html"><span class="fab fa-instagram"></span></a></li>
                        <li><a href="/Realshed/index.html"><span class="fab fa-youtube"></span></a></li>
                    </ul>
                </div>
            </nav>
        </div><!-- End Mobile Menu -->
        <div>
            @RenderBody()

        </div>


<!-- main-footer -->
@await Component.InvokeAsync("_FooterLayoutViewComponentPartial")  @*footer *@
<!-- main-footer end -->
<!--Scroll to top-->
<button class="scroll-top scroll-to-target" data-target="html">
    <span class="fal fa-angle-up"></span>
</button>
    <!-- jequery plugins -->
   
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- bxSlider -->
    <script src="https://cdn.jsdelivr.net/bxslider/4.2.12/jquery.bxslider.min.js"></script>


    <!--  OtherJsLib -->
    <script src="/Realshed/assets/js/popper.min.js"></script>
    <script src="/Realshed/assets/js/bootstrap.min.js"></script>
    <script src="/Realshed/assets/js/wow.js"></script>
    <script src="/Realshed/assets/js/validation.js"></script>
    <script src="/Realshed/assets/js/appear.js"></script>
    <script src="/Realshed/assets/js/scrollbar.js"></script>
    <script src="/Realshed/assets/js/isotope.js"></script>
    <script src="/Realshed/assets/js/jquery.nice-select.min.js"></script>
    <script src="/Realshed/assets/js/jQuery.style.switcher.min.js"></script>
    <script src="/Realshed/assets/js/jquery-ui.js"></script>
    <script src="/Realshed/assets/js/datepicker-tr.js"></script>
    <script src="/Realshed/assets/js/jquery.paroller.min.js"></script>
    <script src="/Realshed/assets/js/owl.js"></script>
    <script src="/Realshed/assets/js/jquery.fancybox.js"></script>
x    <script src="/Realshed/assets/js/nav-tool.js"></script>

    <!-- script.js -->
    <script src="/Realshed/assets/js/script.js"></script>
    <script src="/Realshed/assets/js/nice-select-search.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/lib/toastr/toastr.min.js"></script>
    <script>

             toastr.options = {
            closeButton: true,
            progressBar: true,
            positionClass: "toast-top-center",
            preventDuplicates: true,
            timeOut: "4000"
        };

    </script>
    @if (TempData["Message"] != null)
    {
        <script>

            var messageType = '@TempData["MessageType"]';
            var message = '@TempData["Message"]';

            if (messageType === "success") {
                toastr.success(message);
            }
            else if (messageType === "error") {
                toastr.error(message);
            }
            else if (messageType === "warning") {
                toastr.warning(message);
            }
            else {
                toastr.info(message);
            }

        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)


    <!-- End of .page_wrapper -->
</body>

</html>













