@model List<FibiEmlakDanismanlik.WebUI.Models.AgentFeaturedPropertySidebarVm>

<div class="widget-title">
    <h5>Öne Çıkanlar</h5>
</div>

@if (Model != null && Model.Any())
{
    <div class="single-item-carousel owl-carousel owl-theme owl-nav-none dots-style-one">
        @foreach (var item in Model)
        {
            var imageUrl = !string.IsNullOrWhiteSpace(item.PropImgUrl1)
            ? item.PropImgUrl1
            : Url.Content("~/Realshed/assets/images/feature/feature-1.jpg");

            var description = !string.IsNullOrWhiteSpace(item.PropertyDescription)
            ? (item.PropertyDescription.Length > 120
            ? item.PropertyDescription.Substring(0, 120) + "..."
            : item.PropertyDescription)
            : "İlan açıklaması bulunmuyor.";

            <div class="feature-block-one">
                <div class="inner-box">
                    <div class="image-box">
                        <figure class="image">
                            <img src="@imageUrl" alt="@item.PropertyName">
                        </figure>
                        <div class="batch"><i class="icon-11"></i></div>
                        <span class="category">@item.PropertyStatusLabel</span>
                    </div>

                    <div class="lower-content">
                        <div class="title-text">
                            <h4>
                                <a href="@item.DetailUrl">@item.PropertyName</a>
                            </h4>
                        </div>

                        <div class="price-box clearfix">
                            <div class="price-info">
                                <h6>@item.PropertyStatusLabel</h6>
                                <h4>@item.Price.ToString("N0") TL</h4>
                            </div>
                        </div>

                        <p>@description</p>

                        <div class="btn-box">
                            <a href="@item.DetailUrl" class="theme-btn btn-two">İlanı Gör</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <p>Gösterilecek ilan bulunamadı.</p>
}