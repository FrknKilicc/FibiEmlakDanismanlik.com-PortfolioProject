@model ResultAllForRentalListingForPageDto

<section class="page-title centred" style="background-image: url(https://images.stockcake.com/public/e/3/0/e30fd6b9-27e3-4bf8-95ff-ba161c9d5931_large/real-estate-transaction-stockcake.jpg);">
    <div class="auto-container">
        <div class="content-box clearfix">
            <h1>Kiralık İlanlar</h1>
            <ul class="bread-crumb clearfix">
                <li><a href="@Url.Action("Index","UILayout")">Anasayfa</a></li>
                <li><a href="@Url.Action("Index","AllForRentalPage")">Kiralık İlanlar</a></li>
                <li>İlan Detayı</li>
            </ul>
        </div>
    </div>
</section>
<!--End Page Title-->
<!-- property-details -->
<section class="property-details property-details-one">
    <div class="auto-container">
        <div class="top-details clearfix">
            <div class="left-column pull-left clearfix">
                <h3>@Model.PropertyName</h3>
                <div class="author-info clearfix">
                    <div class="author-box pull-left">
                        <figure class="author-thumb"><img src="@Model.AgentImgUrl" alt=""></figure>
                        <h6>@Model.AgentName</h6>
                    </div>
                    <ul class="rating clearfix pull-left">
                        <li><i class="icon-39"></i></li>
                        <li><i class="icon-39"></i></li>
                        <li><i class="icon-39"></i></li>
                        <li><i class="icon-39"></i></li>
                        <li><i class="icon-40"></i></li>
                    </ul>
                </div>
            </div>
            <div class="right-column pull-right clearfix">
                <div class="price-inner clearfix">
                    <ul class="category clearfix pull-left">
                        <li><a href="property-details.html">@Model.ListingType</a></li>
                        <li><a href="property-details.html">@Model.PropertyStatus</a></li>
                    </ul>
                    <div class="price-box pull-right">
                        <h3>@Model.Rent.ToString("N0") TL</h3>
                        @if (Model.Deposit.HasValue)
                        {
                            <p class="deposit-text">Depozito : @Model.Deposit.Value.ToString("N0") TL</p>
                        }
                    </div>
                </div>
                @await Component.InvokeAsync("_PropertyDetailActionsViewComponentPartial")
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-8 col-md-12 col-sm-12 content-side">
                <div class="property-details-content">
                    @using System.Linq
                    @{
                        var imgs = new List<string?> {
                                        Model.PropImgUrl1, Model.PropImgUrl2, Model.PropImgUrl3, Model.PropImgUrl4,
                                        Model.PropImgUrl5, Model.PropImgUrl6, Model.PropImgUrl7, Model.PropImgUrl8,
                                        Model.PropImgUrl9, Model.PropImgUrl10,
                                        Model.PropImgUrl11, Model.PropImgUrl12, Model.PropImgUrl13, Model.PropImgUrl14, Model.PropImgUrl15,
                                        Model.PropImgUrl16, Model.PropImgUrl17, Model.PropImgUrl18, Model.PropImgUrl19, Model.PropImgUrl20,
                                        Model.PropImgUrl21, Model.PropImgUrl22, Model.PropImgUrl23, Model.PropImgUrl24, Model.PropImgUrl25,
                                        Model.PropImgUrl26, Model.PropImgUrl27, Model.PropImgUrl28, Model.PropImgUrl29, Model.PropImgUrl30
                                        }
                        .Where(x => !string.IsNullOrWhiteSpace(x) && x != "string")
                        .Distinct()
                        .ToList();

                        string NormalizeImgUrl(string raw)
                        {
                            raw = raw.Trim();

                            if (raw.StartsWith("http://") || raw.StartsWith("https://"))
                                return raw;

                            if (raw.StartsWith("/"))
                                return Url.Content("~" + raw);

                            return Url.Content("~/" + raw);
                        }
                    }

                    <div class="carousel-inner">
                        <div class="single-item-carousel owl-carousel owl-theme owl-dots-none">
                            @foreach (var url in imgs)
                            {
                                var fixedUrl = NormalizeImgUrl(url!);
                                <figure class="image-box">
                                    <a class="lightbox-image" href="@fixedUrl" data-fancybox="property-gallery">
                                        <img src="@fixedUrl" alt="">
                                    </a>
                                </figure>
                            }
                        </div>
                    </div>
                    <div class="discription-box content-widget">
                        <div class="title-box">
                            <h4>İlan Açıklaması</h4>
                        </div>
                        <div class="text">
                            <p>@Model.PropertyDescription</p>
                        </div>
                    </div>
                    <div class="details-box content-widget">
                        <div class="title-box">
                            <h4>İlan Detayları</h4>
                        </div>
                        @{
                            var lt = Model?.ListingType?.Trim();
                        }
                        @if (lt == "Konut")
                        {
                            @await Html.PartialAsync("~/Views/Shared/Components/_ForRentalDetailPropertyDetails_Housing/Default.cshtml", Model)
                        }
                        else if (lt == "Arsa")
                        {
                            @await Html.PartialAsync("~/Views/Shared/Components/_ForRentalDetailPropertyDetails_Land/Default.cshtml", Model)
                        }
                        else if (lt == "İşyeri")
                        {
                            @await Html.PartialAsync("~/Views/Shared/Components/_ForRentalDetailPropertyDetails_Commercial/Default.cshtml", Model)
                        }
                    </div>
                    @if (Model?.Amenities != null && Model.Amenities.Any())
                    {
                        <div class="amenities-box content-widget">
                            <div class="title-box">
                                <h4>@Model.ListingType  Özellikler</h4>
                            </div>
                            @await Html.PartialAsync("~/Views/Shared/Components/_AmenitiesListViewComponentPartial/Default.cshtml", Model.Amenities)
                        </div>
                    }
                    @{
                        var items = Model?.FloorPlanImageItems ?? new();
                    }

                    @if (items.Any())
                    {
                        <div class="floorplan-inner content-widget">
                            <div class="title-box">
                                <h4>Plan</h4>
                            </div>

                            <ul class="accordion-box">
                                @for (int i = 0; i < items.Count; i++)
                                {
                                    var isFirst = i == 0;
                                    var item = items[i];
                                    <li class="accordion block @(isFirst ? "active-block" : "")">
                                        <div class="acc-btn @(isFirst ? "active" : "")">
                                            <div class="icon-outer"><i class="fas fa-angle-down"></i></div>
                                            <h5>@item.Title</h5>
                                        </div>
                                        <div class="acc-content @(isFirst ? "current" : "")">
                                            <div class="content-box">
                                                <figure class="image-box">
                                                    <img src="@item.Url" alt="">
                                                </figure>
                                            </div>
                                        </div>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                    <div class="location-box content-widget">
                        <div class="title-box">
                            <h4>Lokasyon</h4>
                        </div>
                        <ul class="info clearfix">
                            <li><span>Address:</span> @Model.AddressDesc</li>
                            <li><span>İl:</span> @Model.City</li>
                            <li><span>İlçe:</span> @Model.District</li>
                            <li><span>Mahalle:</span> @Model.Neighborhood</li>
                        </ul>
                        <div class="google-map-area">
                            <div class="google-map"
                                 id="contact-google-map"
                                 data-api="@ViewBag.ApiUrl"
                                 data-listing-id="@Model.ListingId"
                                 data-listing-type-id="@Model.ListingTypeId"
                                 data-map-zoom="12"
                                 data-icon-path="assets/images/icons/map-marker.png"
                                 data-map-title="@Model.PropertyName">
                            </div>
                        </div>
                    </div>
                    @await Component.InvokeAsync("_NearbyPlacesViewComponentPartial",
                    new { listingId = Model.ListingId, ListingTypeId = Model.ListingTypeId })

                    <div class="schedule-box content-widget">
                        <div class="title-box">
                            <h4>Görüşme Randevusu Talep Et</h4>
                        </div>
                        @{
                            var propertyListingTypeEnum = Model.ListingType == "Arsa" ? 7
                            : Model.ListingType == "Konut" ? 8
                            : 9;
                        }
                        <div class="form-inner">
                            <form asp-action="SendAppointment" asp-controller="Contact" method="post">
                                <input type="hidden" name="PropertyListingId" value="@Model.ListingId" />
                                <input type="hidden" name="PropertyListingTypeEnum" value="@propertyListingTypeEnum" />                                
                                <div class="row clearfix">
                                    <div class="col-lg-6 col-md-12 col-sm-12 column">
                                        <div class="form-group">
                                            <i class="far fa-calendar-alt"></i>
                                            <input type="text" name="date" placeholder="Tarih" id="datepicker" autocomplete="off" class="theme-underline">
                                        </div>
                                    </div>
                                    <div class="col-lg-6 col-md-12 col-sm-12 column">
                                        <div class="form-group">
                                            <i class="far fa-clock" id="timeIcon"></i>
                                            <input type="time" name="time" required class="theme-time theme-underline" autocomplete="off" id="timeInput">
                                        </div>
                                    </div>
                                    <div class="col-lg-4 col-md-12 col-sm-12 column">
                                        <div class="form-group">
                                            <input type="text" name="CustomerContactName" placeholder="İsim Soyisim" required>
                                        </div>
                                    </div>
                                    <div class="col-lg-4 col-md-12 col-sm-12 column">
                                        <div class="form-group">
                                            <input type="email" name="CustomerContactMail" placeholder="E-Mail">
                                        </div>
                                    </div>
                                    <div class="col-lg-4 col-md-12 col-sm-12 column">
                                        <div class="form-group">
                                            <input type="tel" name="CustomerContactPhone" placeholder="Telefon" required inputmode="numeric" pattern="\d{10,15}">
                                        </div>
                                    </div>
                                    <div class="col-lg-12 col-md-12 col-sm-12 column">
                                        <div class="form-group">
                                            <textarea name="CustomerContactMessage"
                                                      placeholder="Mesaj Yaz" maxlength="500"></textarea>
                                        </div>
                                    </div>
                                    <div class="col-lg-12 col-md-12 col-sm-12 column">
                                        <div class="form-group kvkk-row">
                                            <label class="kvkk-label">
                                                <input type="checkbox" name="KvkkApproved" required>
                                                <span>
                                                    KVKK ve Aydınlatma Metnini okudum kabul ediyorum
                                                </span>
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-lg-12 col-md-12 col-sm-12 column">
                                        <div class="form-group message-btn">
                                            <button type="submit" class="theme-btn btn-one">Gönder</button>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-12 col-sm-12 sidebar-side">
                <div class="property-sidebar default-sidebar">
                    <div class="author-widget sidebar-widget">
                        <div class="author-box">
                            <figure class="author-thumb"><img src="@Model.AgentImgUrl" alt=""></figure>
                            <div class="inner">
                                <h4>@Model.AgentName</h4>
                                <ul class="info clearfix">
                                    <li>
                                        <i class="fas fa-map-marker-alt"></i> Telsiz, 85/2. Sk.3A,34020 Zeytinburnu/İstanbul
                                    </li>
                                    <li><i class="fas fa-phone"></i><a href="tel:@Model.AgentPhoneNumber">@Model.AgentPhoneNumber</a></li>
                                    <li><i class="fas fa-envelope"></i><a href="tel:@Model.Mail">@Model.Mail</a></li>

                                </ul>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
