@model List<ResultAgentDto>

@{
    var selectedStatus = Context.Request.Query["status"].ToString();

    if (string.IsNullOrWhiteSpace(selectedStatus))
    {
        selectedStatus = "forRent";
    }
}



<!--Page Title-->
<section class="page-title centred" style="background-image: url(/Realshed/assets/images/background/skyscrapers-pageBanner.jpg);">
    <div class="auto-container">
        <div class="content-box clearfix">
            <h1>Emlak Danışmanlarız</h1>
            <ul class="bread-crumb clearfix">
                <li><a href="@Url.Action("Index","UILayout")">Anasayfa</a></li>
                <li>Ekibimiz</li>
            </ul>
        </div>
    </div>
</section>
<!--End Page Title-->
