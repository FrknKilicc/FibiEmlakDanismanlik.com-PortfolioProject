@model FibiEmlakDanismanlik.Dto.PropertyDtos.ResultAllForSaleListinForPageDto
@using System.Globalization

@functions {
    string YesNo(bool? v) => v == null ? "" : (v.Value ? "Evet" : "Hayır");
    string VarYok(bool? v) => v == null ? "" : (v.Value ? "Var" : "Yok");
    bool Has(string? s) => !string.IsNullOrWhiteSpace(s);
}


<ul class="list clearfix">

    @* Metrekare *@
    @if (Model.NetArea != null)
    {
        <li>Net m²: <span>@Model.NetArea</span></li>
    }
    @if (Model.GrossArea != null)
    {
        <li>Brüt m²: <span>@Model.GrossArea</span></li>
    }
    @if (Model.OpenArea != null)
    {
        <li>Açık Alan m²: <span>@Model.OpenArea</span></li>
    }

    @* Oda / Banyo *@
    @if (Model.NumberOfRoom != null)
    {
        <li>Oda Sayısı: <span>@Model.NumberOfRoom</span></li>
    }
    @if (Model.NumberOfBathRoom != null)
    {
        <li>Banyo Sayısı: <span>@Model.NumberOfBathRoom</span></li>
    }
    @if (Model.NumberOfBalconies != null)
    {
        <li>Balkon Sayısı: <span>@Model.NumberOfBalconies</span></li>
    }

    @* Bina bilgisi *@
    @if (Model.BuildingAge != null)
    {
        <li>Bina Yaşı: <span>@Model.BuildingAge</span></li>
    }
    @if (Model.TotalNumberOfFloor != null)
    {
        <li>Bina Kat Sayısı: <span>@Model.TotalNumberOfFloor</span></li>
    }
    @if (Model.NumberOfFloors != null)
    {
        <li>Bulunduğu Kat: <span>@Model.NumberOfFloors</span></li>
    }
    @if (Has(Model.Facade))
    {
        <li>Cephe: <span>@Model.Facade</span></li>
    }

    @* Konfor/Donanım *@
    @if (Has(Model.Heating))
    {
        <li>Isıtma: <span>@Model.Heating</span></li>
    }
    @if (Model.IsElevator != null)
    {
        <li>Asansör: <span>@VarYok(Model.IsElevator)</span></li>
    }
 
 @* string ise olduğu gibi *@
    @if (Model.Furnished != null)
    {
        <li>Eşyalı: <span>@YesNo(Model.Furnished)</span></li>
    }
    @if (Has(Model.UsageStatus))
    {
        <li>Kullanım Durumu: <span>@Model.UsageStatus</span></li>
    }
    @if (Model.WithinTheComplex != null)
    {
        <li>Site İçinde: <span>@YesNo(Model.WithinTheComplex)</span></li>
    }

    @* Finans / Takas *@
    @if (Model.HomeLoan != null)
    {
        <li>Krediye Uygun: <span>@YesNo(Model.HomeLoan)</span></li>
    }
    @if (Model.Exchange != null)
    {
        <li>Takas: <span>@YesNo(Model.Exchange)</span></li>
    }

    @* Aidat *@
    @if (Model.Dues != null)
    {
        <li>Aidat:
            <span>@Model.Dues.Value.ToString("N2", new CultureInfo("tr-TR")) ₺</span>
        </li>
    }

    @if (Model.PricePerSquareMeter != null)
    {
        <li>
            m² Birim Fiyatı:
            <span>
                @Model.PricePerSquareMeter.Value
                .ToString("N2", new CultureInfo("tr-TR")) ₺
            </span>
        </li>
    }
</ul>