

<!-- about-section -->
@model ResultAboutUsDto
<section class="about-section about-page pb-0">
    <div class="auto-container">
        <div class="inner-container">
            <div class="row align-items-center clearfix">
                <div class="col-lg-6 col-md-12 col-sm-12 image-column">
                    <div class="image_block_2">
                        <div class="image-box">
                            <figure class="image"><img src="@Model.AboutUsImgUrl" alt=""></figure>
                            <div class="text wow fadeInLeft animated" data-wow-delay="00ms" data-wow-duration="1500ms">
                                <h2>10</h2>
                                <h4>Yıldır <br />Yanınızda</h4>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 col-md-12 col-sm-12 content-column">
                    <div class="content_block_3">
                        <div class="content-box">
                            <div class="sec-title">
                                <h5>Hakkımızda</h5>
                                <h2>@Model.AboutUsTitle</h2>
                            </div>
                            <div class="text">
                               @Html.Raw(Model.AboutUsDesc)
                            </div>
                            <div class="btn-box">
                                <a href="@Url.Action("Index","Contact")" class="theme-btn btn-one">Bizimle İletişime Geçin</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- about-section end -->