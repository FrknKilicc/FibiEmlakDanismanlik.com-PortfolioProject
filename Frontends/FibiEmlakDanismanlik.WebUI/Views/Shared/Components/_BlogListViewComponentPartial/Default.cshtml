@model FibiEmlakDanismanlik.WebUI.Models.BlogListingPageVm

<!--Page Title-->
<section class="page-title centred" style="background-image: url(https://images.stockcake.com/public/e/3/0/e30fd6b9-27e3-4bf8-95ff-ba161c9d5931_large/real-estate-transaction-stockcake.jpg);">
    <div class="auto-container">
        <div class="content-box clearfix">
            <h1>Blog Yazıları</h1>
            <ul class="bread-crumb clearfix">
                <li><a href="@Url.Action("Index", "UILayout")">Anasayfa</a></li>
                <li>Blog Yazıları</li>
            </ul>
        </div>
    </div>
</section>

<section class="blog-list sec-pad-2">
    <div class="auto-container">
        <div class="row clearfix">
            @foreach (var item in Model.Items)
            {
                <div class="col-lg-6 col-md-12 col-sm-12 news-block">
                    <div class="news-block-two wow fadeInLeft animated animated" data-wow-delay="00ms" data-wow-duration="1500ms">
                        <div class="inner-box align-items-center">
                            <div style="height:100%" class="image-box">
                                <figure style="height:100%" class="image">
                                    <a asp-controller="Blog" asp-action="Detail" asp-route-id="@item.BlogId">
                                        <img style="height:100%; object-fit:cover;" src="@item.BlogImgUrl" alt="">
                                    </a>
                                </figure>

                                @if (item.TopNews)
                                {
                                    <a asp-controller="Blog" asp-action="Detail" asp-route-id="@item.BlogId" class="feature">Öne Çıkanlar</a>
                                }
                            </div>

                            <div class="content-box">
                                <h4>
                                    <a asp-controller="Blog" asp-action="Detail" asp-route-id="@item.BlogId">
                                        @item.BlogTitle
                                    </a>
                                </h4>

                                <ul class="post-info clearfix">
                                    <li class="author-box">
                                        <figure class="author-thumb">
                                            <img src="@item.AuthorImgUrl" alt="">
                                        </figure>
                                        <h5>
                                            <a asp-controller="Blog" asp-action="Detail" asp-route-id="@item.BlogId">
                                                @item.AuthorName
                                            </a>
                                        </h5>
                                    </li>
                                    <li>@item.CreatedDate.ToString("dd MMMM yyyy")</li>
                                </ul>

                                <p style="display:-webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow:hidden; text-overflow:ellipsis;">
                                    @item.BlogDescription
                                </p>

                                <div class="btn-box">
                                    <a asp-action="Detail" asp-controller="Blog" asp-route-id="@item.BlogId" class="theme-btn btn-two">
                                        Devamını Oku
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @await Html.PartialAsync(
        "~/Views/Shared/Components/_PaginationViewComponentPartial/Default.cshtml",
                new FibiEmlakDanismanlik.WebUI.Models.PaginationVm
                {
                    Page = Model.Page,
                    PageSize = Model.PageSize,
                    TotalPages = Model.TotalPages
                }
                )
    </div>
</section>