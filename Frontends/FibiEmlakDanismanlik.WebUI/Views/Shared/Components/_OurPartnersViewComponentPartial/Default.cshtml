@model List<ResultOurPartnersDto>

<section class="clients-section bg-color-1">
    <div class="pattern-layer" style="background-image: url(realshed/assets/images/shape/shape-1.png);"></div>
    <div class="auto-container">
        <div class="row clearfix">
            <div class="col-lg-4 col-md-12 col-sm-12 title-column">
                <div class="sec-title">
                    <h5>Partnerlerimiz</h5>
                    <h2>Uzun Vadeli İş Ortaklarımız</h2>
                </div>
            </div>
            <div class="col-lg-8 col-md-12 col-sm-12 inner-column">
                <div class="clients-logo">
                    <ul class="logo-list clearfix">
                        @foreach(var item in Model)
                        {
                            <li>
                                <figure class="logo"><a href="index-2.html"><img src="@item.PartnerLogoUrl" alt="@item.PartnerName"></a></figure>
                            </li>
                        }
                      
                        <li>
                            <figure class="logo"><a href="index-2.html"><img src="realshed/assets/images/clients/clients-2.png" alt=""></a></figure>
                        </li>
                        <li>
                            <figure class="logo"><a href="index-2.html"><img src="realshed/assets/images/clients/clients-3.png" alt=""></a></figure>
                        </li>
                       
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
